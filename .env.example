# PostgreSQL 数据库连接
DB_URI=postgresql://kevin:123456@localhost:5432/postgres?sslmode=disable

# Redis 配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# Celery Broker（使用 Redis 作为消息队列）
CELERY_BROKER_URL=redis://localhost:6379/0

# OpenAI 模型配置（可选）
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=your_openai_api_key_here

# 阿里通义千问配置（可选）
DASHSCOPE_API_KEY=your_dashscope_api_key_here

# OneAPI 配置（可选）
ONEAPI_BASE_URL=http://your-oneapi-server:3000/v1
ONEAPI_API_KEY=your_oneapi_api_key_here

# 高德地图 MCP Server Key（可选）
AMAP_MAPS_API_KEY=your_amap_api_key_here
